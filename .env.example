# Ambiente
ENV=development
LOG_LEVEL=INFO

# Proteção obrigatória para não enviar ordens reais durante desenvolvimento
DRY_RUN=true
# Flag de execução transacional (deve iniciar desativada)
ENABLE_ORDER_EXECUTION=false

# Telegram (obrigatório para listener)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_SESSION_NAME=trade_bot_session
# Formato suportado nesta fase: @username público ou inteiro numérico válido (com sinal, se aplicável)
TELEGRAM_SOURCE_CHAT=@your_source_channel

# Bybit (read-only + execução testnet/mainnet)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
# BYBIT_TESTNET=true  → ordens vão para testnet (recomendado para testes)
# BYBIT_TESTNET=false → ordens vão para MAINNET REAL (cuidado!)
BYBIT_TESTNET=true

# Alavancagem para contratos linear (perpétuos USDT)
# Aplicada como buyLeverage e sellLeverage antes de cada trade (one-way mode)
LEVERAGE=10

# Execution planning
# Opções: fixed_notional_usdt | fixed_qty
EXECUTION_SIZING_MODE=fixed_notional_usdt
# Usado quando EXECUTION_SIZING_MODE=fixed_notional_usdt
EXECUTION_FIXED_NOTIONAL_USDT=25
# Usado quando EXECUTION_SIZING_MODE=fixed_qty
EXECUTION_FIXED_QTY=0

# Distribuição de take profits parciais (ordens Limit reduceOnly)
# A soma deve ser exatamente 100.
TP1_PERCENT=50
TP2_PERCENT=20
TP3_PERCENT=20
TP4_PERCENT=10

# Signal source
# Opções: telegram | auto_analysis
SIGNAL_SOURCE=telegram

# Auto analysis (safe-by-default)
AUTO_ANALYSIS_ENABLED=false
AUTO_ANALYSIS_SYMBOL=BTCUSDT
AUTO_ANALYSIS_INTERVAL=60
AUTO_ANALYSIS_EMA_SHORT=5
AUTO_ANALYSIS_EMA_MID=35
AUTO_ANALYSIS_RSI_LEN=14
AUTO_ANALYSIS_MACD_FAST=12
AUTO_ANALYSIS_MACD_SLOW=26
AUTO_ANALYSIS_MACD_SIGNAL=9
AUTO_ANALYSIS_USE_VOLUME_FILTER=false
AUTO_ANALYSIS_VOLUME_MULTIPLIER=1.05
AUTO_ANALYSIS_ADX_LEN=14
AUTO_ANALYSIS_USE_ADX_FILTER=false
AUTO_ANALYSIS_ADX_THRESHOLD=14
AUTO_ANALYSIS_SINGLE_POSITION_ONLY=true
AUTO_ANALYSIS_COOLDOWN_CANDLES=1
