# Ambiente
ENV=development
LOG_LEVEL=INFO

# Proteção obrigatória para não enviar ordens reais durante desenvolvimento
DRY_RUN=true
# Flag de execução transacional (deve iniciar desativada)
ENABLE_ORDER_EXECUTION=false

# Telegram (obrigatório para listener)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_SESSION_NAME=trade_bot_session
# Formato suportado nesta fase: @username público ou inteiro numérico válido (com sinal, se aplicável)
TELEGRAM_SOURCE_CHAT=@your_source_channel

# Bybit (read-only + execução testnet)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

# Execution planning
# Opções: fixed_notional_usdt | fixed_qty
EXECUTION_SIZING_MODE=fixed_notional_usdt
# Usado quando EXECUTION_SIZING_MODE=fixed_notional_usdt
EXECUTION_FIXED_NOTIONAL_USDT=25
# Usado quando EXECUTION_SIZING_MODE=fixed_qty
EXECUTION_FIXED_QTY=0
