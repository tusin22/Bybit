# Ambiente
ENV=development
LOG_LEVEL=INFO

# Modo desta fase (somente leitura; sem execução de ordens)
DRY_RUN=true

# Telegram (obrigatório para listener)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_SESSION_NAME=trade_bot_session
# Formato suportado nesta fase: @username público ou inteiro numérico válido (com sinal, se aplicável)
TELEGRAM_SOURCE_CHAT=@your_source_channel

# Bybit read-only (fase atual)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true
